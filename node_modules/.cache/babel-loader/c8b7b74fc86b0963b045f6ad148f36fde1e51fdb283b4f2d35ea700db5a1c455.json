{"ast":null,"code":"// src/hooks/useScrollReveal.js\nimport{useEffect}from'react';export function useScrollReveal(){useEffect(()=>{const observer=new IntersectionObserver(entries=>{entries.forEach(entry=>{if(entry.isIntersecting){entry.target.classList.add('visible');}});},{threshold:0.08});const elements=document.querySelectorAll('.reveal');elements.forEach(el=>observer.observe(el));return()=>observer.disconnect();});}","map":{"version":3,"names":["useEffect","useScrollReveal","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","target","classList","add","threshold","elements","document","querySelectorAll","el","observe","disconnect"],"sources":["C:/Users/ruben/Desktop/portfolio/src/hooks/useScrollReveal.js"],"sourcesContent":["// src/hooks/useScrollReveal.js\nimport { useEffect } from 'react';\n\nexport function useScrollReveal() {\n  useEffect(() => {\n    const observer = new IntersectionObserver(\n      (entries) => {\n        entries.forEach((entry) => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add('visible');\n          }\n        });\n      },\n      { threshold: 0.08 }\n    );\n\n    const elements = document.querySelectorAll('.reveal');\n    elements.forEach((el) => observer.observe(el));\n\n    return () => observer.disconnect();\n  });\n}\n"],"mappings":"AAAA;AACA,OAASA,SAAS,KAAQ,OAAO,CAEjC,MAAO,SAAS,CAAAC,eAAeA,CAAA,CAAG,CAChCD,SAAS,CAAC,IAAM,CACd,KAAM,CAAAE,QAAQ,CAAG,GAAI,CAAAC,oBAAoB,CACtCC,OAAO,EAAK,CACXA,OAAO,CAACC,OAAO,CAAEC,KAAK,EAAK,CACzB,GAAIA,KAAK,CAACC,cAAc,CAAE,CACxBD,KAAK,CAACE,MAAM,CAACC,SAAS,CAACC,GAAG,CAAC,SAAS,CAAC,CACvC,CACF,CAAC,CAAC,CACJ,CAAC,CACD,CAAEC,SAAS,CAAE,IAAK,CACpB,CAAC,CAED,KAAM,CAAAC,QAAQ,CAAGC,QAAQ,CAACC,gBAAgB,CAAC,SAAS,CAAC,CACrDF,QAAQ,CAACP,OAAO,CAAEU,EAAE,EAAKb,QAAQ,CAACc,OAAO,CAACD,EAAE,CAAC,CAAC,CAE9C,MAAO,IAAMb,QAAQ,CAACe,UAAU,CAAC,CAAC,CACpC,CAAC,CAAC,CACJ","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}